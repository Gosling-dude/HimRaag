rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ──────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ─── Songs ─────────────────────────────────────────────────────────────────
    // Public music catalog — all songs readable without authentication.
    // Firestore range queries (prefix search) on titleLowercase require the
    // collection to be publicly readable; filtering by isApproved is done in
    // app code. isApproved field is still enforced at write-time by admin check.

    match /songs/{songId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ─── Albums ────────────────────────────────────────────────────────────────

    match /albums/{albumId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ─── Artists ───────────────────────────────────────────────────────────────

    match /artists/{artistId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ─── Playlists ─────────────────────────────────────────────────────────────

    match /playlists/{playlistId} {
      allow read: if resource.data.isPublic == true;
      allow read: if isOwner(resource.data.ownerId);
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerId;
      allow update, delete: if isOwner(resource.data.ownerId);
      allow create, update, delete: if isAdmin();
    }

    // ─── Users ─────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      allow read: if isAdmin();
    }

    // ─── Categories ────────────────────────────────────────────────────────────

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ─── Regions ───────────────────────────────────────────────────────────────

    match /regions/{regionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ─── Featured / Banners ────────────────────────────────────────────────────

    match /featured/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /banners/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
